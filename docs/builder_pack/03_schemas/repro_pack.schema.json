    "id",
    "timestamp",
    "models",
    "params",
    "hashes",
    "versions"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "models": {
      "type": "array"
    },
    "params": {
      "type": "object"
    },
    "hashes": {
      "type": "object"
    },
    "versions": {
      "type": "object"
    },
    "hardware_profile": {
      "type": "object"
    },
    "retrieval_refs": {
      "type": "array"
    }
  },
  "additionalProperties": true
}

    "task_id",
    "events"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "events": {
      "type": "array"
    },
    "metrics": {
      "type": "object"
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
